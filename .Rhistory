# 1. Define the unique collection ID from your URL
collection_uuid <- "26b5b4f6-828c-4791-b4a3-abb19e3b1952"
# 2. Get the list of datasets in the collection
# This step helps confirm the datasets available for download
datasets <- get_datasets(collection_uuid)
# The collection likely contains only one dataset, so we target the first one.
# You may need to inspect the 'datasets' object if there are multiple.
dataset_uuid <- datasets$dataset_id[1]
# 3. Create a temporary directory for the download
temp_dir <- tempdir()
# 4. Download the dataset file (usually in .h5ad format)
# This will download the file to the specified directory
h5ad_file_path <- download_dataset(
dataset_uuid,
dest_path = temp_dir,
file_ext = "h5ad"
)
# Convert the h5ad file to a SingleCellExperiment object
sce <- readH5AD(h5ad_file_path)
# You can now view the structure of your loaded data
print(sce)
# To view cell metadata (e.g., cell type, tissue)
head(colData(sce))
# To view gene metadata (e.g., gene names, features)
head(rowData(sce))
# The primary count matrix is usually stored as 'counts' or 'X'
# Access the count matrix using the assay() function
# dim(assay(sce)) # Check dimensions: (genes x cells)
# The UMAP/tSNE coordinates are typically stored here
# reducedDims(sce)
# 3. Create a temporary directory for the download
temp_dir <- tempdir()
# 4. Download the dataset file (usually in .h5ad format)
# This will download the file to the specified directory
h5ad_file_path <- download_dataset(
dataset_uuid,
dest_path = temp_dir,
file_ext = "h5ad"
)
# Convert the h5ad file to a SingleCellExperiment object
sce <- readH5AD(h5ad_file_path)
