out_dir = "output_CART"
mtx <- readMM(paste0(out_dir,"/matrix.mtx"))
# read barcodes and genes
barcodes <- read.table(paste0(out_dir,"/barcodes.tsv"), stringsAsFactors = FALSE)[,1]
genes_df <- read.table(paste0(out_dir,"/genes_symbol.tsv"), stringsAsFactors = FALSE)
genes_name = genes_df[,2]
meta = read.csv(paste0(out_dir,"/meta.csv"),
row.names = 1)
rownames(mtx) <- barcodes
genes_name <- make.unique(genes_name)   # in case of duplicate gene symbols
colnames(mtx) <- genes_name
